# Copy this file to .env and fill in your real values.
# Do NOT commit .env to git if it contains secrets.

SECRET_KEY=change-me-to-a-secure-key
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ai_novels

# LLM endpoints / keys
API_ENDPOINT_1=https://open.bigmodel.cn/api/paas/v4/
API_KEY_1=your_api_key_1
MODEL_NAME_1=glm-4.5-air
API_ENDPOINT_POOL_1=
API_KEY_POOL_1=

API_ENDPOINT_2=https://open.bigmodel.cn/api/paas/v4/
API_KEY_2=your_api_key_2
MODEL_NAME_2=glm-4.5-air
API_ENDPOINT_POOL_2=
API_KEY_POOL_2=

API_ROUTE_FAILURE_THRESHOLD=2
API_ROUTE_COOLDOWN_SECONDS=30

# Billing
COINS_PER_1000_TOKENS=1
COINS_PER_YUAN=10
MIN_RECHARGE_AMOUNT_YUAN=10
DEFAULT_ESTIMATED_OUTPUT_TOKENS=1200
PAYMENT_SUBJECT_PREFIX=小说创作代币充值

# Alipay
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/workspace/page/wallet

# Runtime / security
ENVIRONMENT=production
FORCE_HTTPS=1
TRUST_PROXY=1
SESSION_COOKIE_SECURE=1
REMEMBER_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax

# Login / session
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=900
LOGIN_CAPTCHA_TTL_SECONDS=180
SESSION_INACTIVITY_TIMEOUT_SECONDS=600

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_TO_STDOUT=1
LOG_MAX_BYTES=20971520
LOG_BACKUP_COUNT=10

# Mail (optional)
MAIL_HOST=
MAIL_PORT=465
MAIL_USE_TLS=0
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=
MAIL_TIMEOUT_SECONDS=8

# Optional master key for encrypted values
APP_CONFIG_MASTER_KEY=
APP_CONFIG_MASTER_KEY_FILE=

# Deprecated: admin password is now managed in admin backend security settings.
