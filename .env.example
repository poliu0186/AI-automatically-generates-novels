# Copy this file to .env and fill in your real values.
# Do NOT commit .env to git if it contains secrets.

SECRET_KEY=change-me-to-a-secure-key
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ai_novels
API_ENDPOINT_1=https://open.bigmodel.cn/api/paas/v4/
API_KEY_1=your_api_key_1
API_ENDPOINT_2=https://open.bigmodel.cn/api/paas/v4/
API_KEY_2=your_api_key_2
COINS_PER_1000_TOKENS=1
COINS_PER_YUAN=10
MIN_RECHARGE_AMOUNT_YUAN=10
DEFAULT_ESTIMATED_OUTPUT_TOKENS=1200
PAYMENT_SUBJECT_PREFIX=小说创作代币充值
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/workspace/page/wallet
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password
